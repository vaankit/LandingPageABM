PORT=3001
HOST=0.0.0.0
APP_URL=http://localhost:3001
PUBLIC_BASE_URL=http://localhost:3001
PUBLIC_BOOKING_API_URL=http://localhost:3001
PUBLIC_BOOKING_ALLOWED_ORIGINS=*
SUPABASE_URL=
SUPABASE_ANON_KEY=
ALLOW_SELF_SIGNUP=false
PUBLISH_PROVIDER=local-json
CONTENT_PROVIDER=ollama
OLLAMA_API_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2:latest

# Used by the generic HTTP publisher when you're ready to wire the new API.
PUBLISH_API_URL=
PUBLISH_API_TOKEN=
PUBLISH_API_AUTH_HEADER=Authorization
PUBLISH_API_AUTH_SCHEME=Bearer

# Optional: customize outgoing payload shape later.
PUBLISH_PROJECT_NAME=Spot.AI Landing Pages

# Public booking + calendar flow
BOOKING_DURATION_MINUTES=30
BOOKING_OWNER_EMAIL=
BOOKING_OWNER_TIMEZONE=Pacific/Auckland
BOOKING_CREATE_MEET_LINK=true
BOOKING_NOTIFICATION_WEBHOOK_URL=
BOOKING_LOG_ENABLED=true
BOOKING_RATE_LIMIT_WINDOW_MS=900000
BOOKING_RATE_LIMIT_MAX=10
BOOKING_BUSINESS_START_HOUR=9
BOOKING_BUSINESS_END_HOUR=17
BOOKING_LOOKAHEAD_DAYS=14
BOOKING_SLOT_INTERVAL_MINUTES=30

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Twilio voice callback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MACHINE_DETECTION=Enable

# OpenAI realtime voice agent
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=marin
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
